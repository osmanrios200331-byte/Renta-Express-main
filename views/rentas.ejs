<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rentas</title>
 <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <!-- Bootstrap -->
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/bootstrap-icons.css">

    
    <!-- Tus estilos -->
    <link rel="stylesheet" href="/css/stylesadmin.css">
    <link rel="stylesheet" href="/css/stylesinicio.css">


</head>


<body>

    <div class="main-container">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="logo">
                <img src="/img/logoOscuro.png" alt="logo">
            </div>

            <nav>
                <a href="/inicioAdmin" class="nav-item "><i class="bi bi-house-door"></i> Inicio</a>
                <a href="/clientes" class="nav-item"><i class="bi bi-people"></i> Clientes</a>
                <a href="/vehiculos" class="nav-item"><i class="bi bi-truck"></i> Vehículos</a>
                <a href="/rentas" class="nav-item active"><i class="bi bi-file-earmark-text"></i> Rentas</a>
                <a href="/pagos" class="nav-item"><i class="bi bi-coin"></i> Pagos</a>
                <a href="/reportes" class="nav-item"> <i class="bi bi-file-earmark-bar-graph"></i> Reportes</a>
            </nav>
        </aside>

        <!-- CONTENIDO -->
        <div class="content">

            <!-- HEADER -->
            <header class="topbar">
                <button id="menuToggle" class="menu-btn">☰</button>

                <div class="user" id="userMenu">
                    <img src="/img/logoClaro.png" alt="user">
                    <div class="dropdown" id="dropdownMenu">
                        <button>👤 Mi perfil</button>
                        <button>⚙️ Configuración</button>
                        <button id="logoutBtn">🚪 Cerrar sesión</button>
                    </div>
                </div>
            </header>

            <!-- MAIN -->
            <main class="dashboard">
                <div class="card shadow-sm p-3">

                    <!-- TITULO -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2>Gestión de Rentas</h2>
                            <p>Administra y controla las rentas realizadas.</p>
                        </div>

                        <!-- 🔥 BOTÓN FUNCIONAL -->
                        <button class="btn fw-bold px-4 py-2"
                            style="background:#f4a62a; color:white; border-radius:12px;" data-bs-toggle="modal"
                            data-bs-target="#modalNuevaRenta">
                            <i class="bi bi-plus-lg"></i> Nueva Renta
                        </button>
                    </div>

                    <!-- TARJETA -->
                    <div class="mb-3">
                        <div style="background:#2e6f3e; color:white; padding:20px; border-radius:12px; width:140px;">
                            <h4 class="mb-0" id="totalRentas">0</h4>
                            <small>Rentas</small>
                        </div>
                    </div>

                    <!-- BUSCADOR -->
                    <div class="d-flex gap-2 mb-3">
                        <div class="flex-grow-1 position-relative">
                            <i class="bi bi-search position-absolute" style="top:10px; left:10px;"></i>
                            <input type="text" id="buscadorRentas" class="form-control ps-4"
                                placeholder="Buscar por cliente o placa">
                        </div>

                        <button class="btn btn-light border">
                            <i class="bi bi-funnel"></i> Filtrar
                        </button>
                    </div>

                    <!-- TABLA -->
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Id</th>
                                    <th>Cliente</th>
                                    <th>Vehículo</th>
                                    <th>Placa</th>
                                    <th>Fecha Inicio</th>
                                    <th>Fecha Fin</th>
                                    <th>Valor Total</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tablaRentas"></tbody>
                        </table>
                    </div>

                    <!-- PAGINACIÓN -->
                    <div class="d-flex justify-content-between mt-3">
                        <small id="infoTabla">0 registros</small>
                        <div>
                            <button class="btn btn-sm btn-light border">‹</button>
                            <button class="btn btn-sm btn-dark">1</button>
                            <button class="btn btn-sm btn-light border">›</button>
                        </div>
                    </div>

                </div>
            </main>

            <!-- FOOTER -->
            <footer>
                © 2026 Renta Express. Todos los derechos reservados.
            </footer>

        </div>
    </div>

    <!-- MODAL -->
    <div class="modal fade" id="modalNuevaRenta" tabindex="-1">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content p-3">

            <h5 class="text-center fw-bold mb-4">Detalles Renta</h5>

            <div class="row g-3">

                <!-- CLIENTE -->
                <div class="col-md-6">
                    <label class="form-label">Cliente</label>
                    <select class="form-control" id="cliente">
                        <option value="">Seleccionar cliente</option>
                    </select>
                </div>

                <!-- FECHA FIN -->
                <div class="col-md-6">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" class="form-control" id="fechaFin">
                </div>

                <!-- VEHICULO -->
                <div class="col-md-6">
                    <label class="form-label">Vehículo</label>
                    <select class="form-control" id="vehiculo">
                        <option value="">Seleccionar vehículo</option>
                    </select>
                </div>

                <!-- TARIFA -->
                <div class="col-md-6">
                    <label class="form-label">Tarifa Aplicada</label>
                    <input type="number" class="form-control" id="tarifa">
                </div>

                <!-- FECHA INICIO -->
                <div class="col-md-6">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" class="form-control" id="fechaInicio">
                </div>

                <!-- TOTAL -->
                <div class="col-md-6">
                    <label class="form-label">Valor Total</label>
                    <input type="number" class="form-control" id="total" readonly>
                </div>

            </div>

            <div class="text-center mt-4">
                <button class="btn px-5 fw-bold"
                    style="background:#0b1c3d; color:white; border-radius:10px;"
                    id="btnGuardarRenta">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>
    <!-- JS -->
    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/menu.js"></script>
    <script src="/js/rentas.js"></script>

</body>

</html>