<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/stylesadmin.css">
    <link rel="stylesheet" href="/css/stylesinicio.css">
</head>

<body>
    <div class="main-container">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="logo">
                <img src="/img/logoOscuro.png" alt="logo">
            </div>
            <nav>
                <a href="/inicioAdmin" class="nav-item"><i class="bi bi-house-door"></i> Inicio</a>
                <a href="/clientes" class="nav-item"><i class="bi bi-people"></i> Clientes</a>
                <a href="/vehiculos" class="nav-item"><i class="bi bi-truck"></i> Vehículos</a>
                <a href="/rentas" class="nav-item"><i class="bi bi-file-earmark-text"></i> Rentas</a>
                <a href="/pagos" class="nav-item"><i class="bi bi-coin"></i> Pagos</a>
                <a href="/reportes" class="nav-item active"><i class="bi bi-file-earmark-bar-graph"></i> Reportes</a>
            </nav>
        </aside>

        <!-- CONTENIDO -->
        <div class="content">

            <!-- HEADER -->
            <header class="topbar">
                <button id="menuToggle" class="menu-btn">☰</button>
                <div class="user" id="userMenu">
                    <img src="/img/logoClaro.png" alt="user">
                    <div class="dropdown" id="dropdownMenu">
                        <button>👤 Mi perfil</button>
                        <button>⚙️ Configuración</button>
                        <button id="logoutBtn">🚪 Cerrar sesión</button>
                    </div>
                </div>
            </header>

            <!-- MAIN -->
            <main class="dashboard">

                <!-- TITULO -->
                <div class="mb-4">
                    <h2>Reportes</h2>
                    <p>Visualiza estadísticas y métricas del sistema.</p>
                </div>

                <!-- TARJETAS RESUMEN -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card shadow-sm p-3 text-center">
                            <h6 class="text-muted">Total Rentas</h6>
                            <h3 id="totalRentas" class="fw-bold">0</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm p-3 text-center">
                            <h6 class="text-muted">Total Ingresos</h6>
                            <h3 id="totalIngresos" class="fw-bold">$0</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm p-3 text-center">
                            <h6 class="text-muted">Total Pagos</h6>
                            <h3 id="totalPagos" class="fw-bold">0</h3>
                        </div>
                    </div>
                </div>

                <!-- GRAFICAS -->
                <div class="row g-3">

                    <!-- Rentas por mes -->
                    <div class="col-md-6">
                        <div class="card shadow-sm p-3">
                            <h6 class="fw-bold mb-3">
                                <i class="bi bi-bar-chart"></i> Rentas por Mes
                            </h6>
                            <canvas id="graficaRentas"></canvas>
                        </div>
                    </div>

                    <!-- Ingresos por mes -->
                    <div class="col-md-6">
                        <div class="card shadow-sm p-3">
                            <h6 class="fw-bold mb-3">
                                <i class="bi bi-graph-up"></i> Ingresos por Mes
                            </h6>
                            <canvas id="graficaIngresos"></canvas>
                        </div>
                    </div>

                </div>

            </main>

            <!-- FOOTER -->
            <footer>
                © 2026 Renta Express. Todos los derechos reservados.
            </footer>

        </div>
    </div>

    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/menu.js"></script>
    <script src="/js/reportes.js"></script>

</body>
</html>